generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String        @id @default(uuid())
  name            String
  email           String        @unique
  password        String?
  address         String?
  phone           String?
  role            Role          @default(CUSTOMER)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  isVerified      Boolean       @default(false)
  avatar          String?
  googleId        String?       @unique
  pushToken       String?
  latitude        Float?
  longitude       Float?
  termsAcceptedAt DateTime?
  isOnline        Boolean       @default(false)
  isEmailVerified Boolean       @default(false)
  orders          Order[]       @relation("CustomerOrders")
  deliveries      Order[]       @relation("RiderOrders")
  otp             Otp[]
  restaurant      Restaurant?   @relation("RestaurantOwner")
  transactions    Transaction[]
  logisticsCompanyId String?
  logisticsCompany   LogisticsCompany? @relation("CompanyRiders", fields: [logisticsCompanyId], references: [id])

  @@index([role])
  @@index([isOnline])
  @@index([phone])
}

model Otp {
  id        String   @id @default(cuid())
  code      String
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
  used      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, code])
  @@index([expiresAt])
}

model Restaurant {
  id           String         @id @default(uuid())
  name         String
  address      String
  phone        String
  ownerId      String         @unique
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  imageUrl     String?
  isOpen       Boolean        @default(false)
  minimumOrder Float          @default(0.0)
  email        String         @unique
  prepTime     Int            @default(20)
  latitude     Float?
  longitude    Float?
  rating       Float          @default(0.0)
  ratingCount  Int            @default(0)
  slug         String?        @unique
  categories   MenuCategory[]
  menuItems    MenuItem[]
  orders       Order[]
  owner        User           @relation("RestaurantOwner", fields: [ownerId], references: [id])

  @@index([isOpen])
  @@index([rating])
}

model MenuCategory {
  id           String     @id @default(uuid())
  name         String
  restaurantId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItems    MenuItem[]

  @@index([restaurantId])
}

model MenuItem {
  id           String       @id @default(uuid())
  name         String
  price        Float
  available    Boolean      @default(true)
  restaurantId String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  imageUrl     String?
  categoryId   String
  deletedAt    DateTime?
  category     MenuCategory @relation(fields: [categoryId], references: [id])
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([categoryId])
  @@index([available, deletedAt])
}

model Order {
  id                  String        @id @default(uuid())
  customerId          String
  restaurantId        String
  totalAmount         Float
  status              OrderStatus   @default(PENDING)
  paymentStatus       PaymentStatus @default(PENDING)
  deliveryAddress     String
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  reference           String        @unique
  deliveryFee         Float
  deliveryDistance     Float?
  deliveryNotes       String?
  token               String?       @unique
  deliveryLatitude    Float?
  deliveryLongitude   Float?
  checkoutUrl         String?
  idempotencyKey      String?       @unique
  riderId             String?
  deliveryCode        String?
  riderName           String?
  riderPhone          String?
  deliveryPhoneNumber String
  customer            User          @relation("CustomerOrders", fields: [customerId], references: [id])
  restaurant          Restaurant    @relation(fields: [restaurantId], references: [id])
  rider               User?         @relation("RiderOrders", fields: [riderId], references: [id])
  items               OrderItem[]
  transactions        Transaction[]

  @@index([restaurantId])
  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([riderId])
  @@index([createdAt])
}

model OrderItem {
  id           String  @id @default(uuid())
  orderId      String
  menuItemId   String?
  quantity     Int
  price        Float
  menuItemName String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Transaction {
  id          String              @id @default(uuid())
  userId      String
  amount      Float
  type        TransactionType
  category    TransactionCategory
  status      TransactionStatus   @default(PENDING)
  orderId     String?
  description String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  reference   String?             @unique
  order       Order?              @relation(fields: [orderId], references: [id])
  user        User                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([orderId])
  @@index([status, type])
  @@index([createdAt])
}

model LogisticsCompany {
  id                   String   @id @default(uuid())
  name                 String
  managerEmail         String   @unique
  inviteCode           String   @unique
  bankName             String
  accountNumber        String
  showEarningsToRiders Boolean  @default(false)
  riders               User[]   @relation("CompanyRiders")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([inviteCode])
}

enum OrderStatus {
  PENDING
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  READY_FOR_PICKUP
  RIDER_ACCEPTED
  UNDERPAID
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  UNDERPAID
}

enum Role {
  CUSTOMER
  VENDOR
  ADMIN
  RIDER
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionCategory {
  ORDER_EARNING
  DELIVERY_FEE
  PLATFORM_FEE
  WITHDRAWAL
  REFUND
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}
